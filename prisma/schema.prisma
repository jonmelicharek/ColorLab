// ===========================================
// ColorLab AI — Database Schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── FORMULA DATABASE (populated by you) ────────────────────

model FormulaEntry {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  beforeImageUrl  String
  beforeHairColor String
  beforeHairType  String?
  beforeCondition String?
  beforeLevel     Int?

  afterImageUrl   String
  afterHairColor  String
  afterLevel      Int?

  technique       String
  formulaDetails  String

  colorBrand      String?
  colorLine       String?
  colorShades     String[]
  developer       String?
  developerRatio  String?
  lightener       String?
  lightenerMix    String?
  toner           String?
  tonerDeveloper  String?
  additives       String[]
  processingTime  String?

  tags            String[]
  difficulty      String?
  priceRange      String?
  estimatedTime   String?

  colorVector     String?
  notes           String?

  analyses        Analysis[]

  @@index([tags])
  @@index([technique])
  @@index([beforeLevel])
  @@index([afterLevel])
}

// ─── USER SUBMISSIONS ───────────────────────────────────────

model Submission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  clientImageUrl  String
  inspoImageUrl   String

  clientHairInfo  Json?
  inspoHairInfo   Json?

  stylistId       String?
  stylist         Stylist?  @relation(fields: [stylistId], references: [id])

  analysis        Analysis?

  @@index([stylistId])
}

model Analysis {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  submissionId    String   @unique
  submission      Submission @relation(fields: [submissionId], references: [id])

  summary         String
  recommendedFormula String
  technique       String
  estimatedTime   String?
  difficulty      String?
  warnings        String[]
  tips            String[]

  // "Why This Works" premium content
  whyThisWorks    Json?

  matchedEntryId  String?
  matchedEntry    FormulaEntry? @relation(fields: [matchedEntryId], references: [id])
  matchConfidence Float?

  rawAiResponse   Json?

  @@index([matchedEntryId])
}

// ─── STYLIST ACCOUNTS & SUBSCRIPTIONS ────────────────────────

model Stylist {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  email           String   @unique
  name            String
  salon           String?
  city            String?
  state           String?
  phone           String?
  instagram       String?
  specialties     String[]

  // Auth
  authCode        String?
  authCodeExpiry  DateTime?
  sessionToken    String?   @unique
  lastLoginAt     DateTime?

  // Subscription
  stripeCustomerId    String?   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId       String?
  plan                String    @default("free") // free, stylist, salon, enterprise
  planStatus          String    @default("active") // active, canceled, past_due
  planExpiresAt       DateTime?

  // "Why This Works" add-on
  hasWhyAddon         Boolean   @default(false)
  whyAddonStripeId    String?

  // Usage tracking
  submissions     Submission[]
  analysisCount   Int      @default(0)
  freeAnalysesUsed Int     @default(0)
  monthlyResetAt  DateTime?

  // Client profiles
  clients         Client[]

  // Saved formulas
  savedFormulas   SavedFormula[]

  // Lead gen tracking
  source          String?
  referralCode    String?  @unique
  referredBy      String?

  @@index([email])
  @@index([stripeCustomerId])
  @@index([sessionToken])
}

// ─── CLIENT PROFILES ────────────────────────────────────────

model Client {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stylistId       String
  stylist         Stylist  @relation(fields: [stylistId], references: [id])

  name            String
  email           String?
  phone           String?
  instagram       String?
  notes           String?

  // Hair info
  naturalLevel    Int?
  currentColor    String?
  hairType        String?
  porosity        String?
  condition       String?
  grayPercentage  Int?
  allergies       String?

  // Photos
  photoUrl        String?

  // Relations
  savedFormulas   SavedFormula[]

  @@index([stylistId])
}

// ─── SAVED FORMULAS ─────────────────────────────────────────

model SavedFormula {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  stylistId       String
  stylist         Stylist  @relation(fields: [stylistId], references: [id])

  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id])

  // Analysis data
  clientImageUrl  String?
  inspoImageUrl   String?
  analysisResult  Json     // Full analysis JSON
  notes           String?
  favorite        Boolean  @default(false)

  @@index([stylistId])
  @@index([clientId])
}

// ─── ANONYMOUS USAGE TRACKING ──────────────────────────────

model AnonymousUsage {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  // Tracking keys
  ipAddress       String
  deviceId        String   @unique  // httpOnly cookie value

  // Usage
  analysesUsed    Int      @default(0)
  monthlyResetAt  DateTime?

  @@index([ipAddress])
  @@index([deviceId])
}

// ─── SOCIAL MEDIA POSTS ─────────────────────────────────────

model SocialPost {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  // Content
  caption         String
  imageUrl        String?
  imagePrompt     String?  // AI description for image sourcing
  hook            String?  // First line / scroll-stopper

  // Post metadata
  postType        String?  // tip, trend, education, promotion, engagement, etc.
  status          String   @default("draft") // draft, scheduled, published, failed

  // Instagram data
  igMediaId       String?
  permalink       String?
  publishedAt     DateTime?

  // Scheduling
  scheduledFor    DateTime?

  @@index([status])
  @@index([publishedAt])
  @@index([scheduledFor])
}

// ─── LEAD GEN & WAITLIST ────────────────────────────────────

model Lead {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  email           String   @unique
  name            String?
  salon           String?
  city            String?
  phone           String?
  instagram       String?

  source          String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?

  emailsSent      Int      @default(0)
  lastEmailAt     DateTime?
  converted       Boolean  @default(false)
  convertedAt     DateTime?

  @@index([email])
  @@index([source])
}

// ─── AFFILIATE / BRAND PARTNERS ─────────────────────────────

model Affiliate {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Company info
  brandName       String
  contactName     String
  contactEmail    String   @unique
  phone           String?
  website         String?

  // Products they want featured
  productLines    String[] // e.g. ["Shades EQ", "Flash Lift"]
  colorBrands     String[] // e.g. ["Redken"]

  // Tracking
  affiliateCode   String   @unique
  commissRate     Float    @default(0.10) // 10% default

  // Status
  status          String   @default("pending") // pending, approved, active, paused
  approvedAt      DateTime?

  // Metrics
  impressions     Int      @default(0) // times products shown in results
  clicks          Int      @default(0) // clicks on product links
  conversions     Int      @default(0)
  totalRevenue    Float    @default(0)

  // Payment
  payoutEmail     String?
  totalPaid       Float    @default(0)

  notes           String?

  @@index([affiliateCode])
  @@index([status])
}

// ─── CLIENT PORTAL (for salons to buy leads) ────────────────

model SalonAccount {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  salonName       String
  ownerName       String
  email           String   @unique
  phone           String?
  city            String?
  state           String?
  zipCode         String?
  website         String?
  instagram       String?

  // Subscription
  stripeCustomerId    String?   @unique
  plan                String    @default("basic") // basic, premium
  creditsRemaining    Int       @default(0) // lead credits

  // Preferences
  serviceRadius       Int       @default(25) // miles
  preferredServices   String[]  // e.g. ["balayage", "color correction"]

  // Status
  verified            Boolean   @default(false)
  active              Boolean   @default(true)

  // Relations
  purchasedLeads      SalonLead[]

  @@index([email])
  @@index([city, state])
}

model SalonLead {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  // The client looking for service
  clientName      String?
  clientEmail     String
  clientPhone     String?
  clientCity      String?
  serviceWanted   String   // e.g. "Balayage - Brown to Blonde"
  inspoImageUrl   String?

  // Pricing
  price           Float    @default(5.00) // cost per lead

  // Status
  status          String   @default("available") // available, sold, contacted, converted

  // Purchasing salon
  salonId         String?
  salon           SalonAccount? @relation(fields: [salonId], references: [id])
  purchasedAt     DateTime?
  contactedAt     DateTime?
  convertedAt     DateTime?

  notes           String?

  @@index([status])
  @@index([clientCity])
  @@index([salonId])
}
