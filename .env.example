# ===========================================
# ColorLab AI — Environment Variables
# ===========================================

# Anthropic API Key (for Claude Vision image analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Vercel Blob Storage (for image uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxx

# Database (Vercel Postgres or any Postgres URL)
DATABASE_URL="postgresql://user:password@host:5432/colorlab?sslmode=require"

# Resend (for lead gen emails)
RESEND_API_KEY=re_xxxxx

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="ColorLab AI"

# Admin Secret (for accessing /admin routes)
ADMIN_SECRET=your-secret-key-here

# Optional: Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
